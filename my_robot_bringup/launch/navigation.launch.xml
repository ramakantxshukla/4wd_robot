<launch>
<!--  Paths  -->
<let name="rviz_config_path" value="$(find-pkg-share my_robot_bringup)/rviz/navigation.rviz"/>
<let name="localization_params_path" value="$(find-pkg-share my_robot_bringup)/config/amcl_localization.yaml"/>
<let name="navigation_params_path" value="$(find-pkg-share my_robot_bringup)/config/navigation.yaml"/>
<let name="map_file_path" value="$(find-pkg-share my_robot_bringup)/worlds/my_custom.yaml"/>
<!--  Arguments  -->
<arg name="rviz" default="true" description="Open RViz"/>
<arg name="use_sim_time" default="True" description="Flag to enable use_sim_time"/>
<!--  RViz  -->
<node pkg="rviz2" exec="rviz2" if="$(var rviz)" output="screen" args="-d $(var rviz_config_path)">
<param name="use_sim_time" value="$(var use_sim_time)"/>
</node>
<!--  AMCL Node  -->
<node pkg="nav2_amcl" exec="amcl" name="amcl" output="screen">
<param name="use_sim_time" value="$(var use_sim_time)"/>
<param from="$(var localization_params_path)"/>
</node>
<!--  Nav2 Localization  -->
<include file="$(find-pkg-share nav2_bringup)/launch/localization_launch.py">
<arg name="use_sim_time" value="$(var use_sim_time)"/>
<arg name="params_file" value="$(var localization_params_path)"/>
<arg name="map" value="$(var map_file_path)"/>
</include>
<!--  Nav2 Navigation  -->
<include file="$(find-pkg-share nav2_bringup)/launch/navigation_launch.py">
<arg name="use_sim_time" value="$(var use_sim_time)"/>
<arg name="params_file" value="$(var navigation_params_path)"/>
</include>
</launch>