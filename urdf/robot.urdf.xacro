<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="4wd_robot">

  <!-- Include robot components -->
  <xacro:include filename="$(find 4wd_robot)/urdf/robot_core.xacro" />
  <xacro:include filename="$(find 4wd_robot)/urdf/lidar.xacro" />
  <xacro:include filename="$(find 4wd_robot)/urdf/imu.xacro" />
  <xacro:include filename="$(find 4wd_robot)/urdf/gazebo_control.xacro" />

</robot>
